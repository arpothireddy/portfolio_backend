[Unit]
Description=Cloudflare quick tunnel for avinash-agent-backend
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=avi
ExecStart=/home/avi/.local/bin/cloudflared tunnel --url http://127.0.0.1:8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
